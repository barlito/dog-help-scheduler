{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}
    <div class="card mb-4">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3 py-2">
            <form method="post" action="{{ path('admin_trigger_notification') }}" class="m-0">
                <input type="hidden" name="_token" value="{{ csrf_token('trigger_notification') }}">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa fa-bell me-1"></i> Déclencher une notif
                </button>
            </form>

            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="d-flex align-items-center" aria-label="Navigation dans les périodes">
                    {% if period != 'all' %}
                        <a href="{{ path('admin', {period: period, anchor: prevAnchor|date('Y-m-d')}) }}"
                           class="btn btn-sm btn-link text-secondary px-2" title="Période précédente">
                            <i class="fa fa-chevron-left"></i>
                        </a>
                    {% endif %}
                    <span class="fw-semibold text-nowrap px-1">
                        <i class="fa fa-calendar-days text-secondary me-1"></i>{{ rangeLabel }}
                    </span>
                    {% if period != 'all' %}
                        {% if nextAnchor <= today %}
                            <a href="{{ path('admin', {period: period, anchor: nextAnchor|date('Y-m-d')}) }}"
                               class="btn btn-sm btn-link text-secondary px-2" title="Période suivante">
                                <i class="fa fa-chevron-right"></i>
                            </a>
                        {% else %}
                            <span class="btn btn-sm btn-link text-secondary px-2 disabled opacity-25">
                                <i class="fa fa-chevron-right"></i>
                            </span>
                        {% endif %}
                        {% if not isCurrentPeriod %}
                            <a href="{{ path('admin', {period: period}) }}"
                               class="btn btn-sm btn-outline-secondary ms-2" title="Revenir à la période en cours">
                                Aujourd'hui
                            </a>
                        {% endif %}
                    {% endif %}
                </div>

                <ul class="nav nav-pills gap-1" aria-label="Période des statistiques">
                    {% for p, label in {week: 'Semaine', month: 'Mois', all: 'Global'} %}
                        <li class="nav-item">
                            <a class="nav-link py-1 px-3{{ period == p ? ' active' }}"
                               href="{{ path('admin', {period: p, anchor: anchor|date('Y-m-d')}) }}">{{ label }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 col-6 mb-3">
            <div class="card text-bg-success h-100">
                <div class="card-body">
                    <h2 class="mb-0">{{ successRate }}%</h2>
                    <div>Taux de réussite</div>
                    <small class="opacity-75">Validées / délivrées</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card text-bg-info h-100">
                <div class="card-body">
                    <h2 class="mb-0">{{ responseRate }}%</h2>
                    <div>Taux de réponse</div>
                    <small class="opacity-75">Répondues / délivrées</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="mb-0">{{ delivered }}</h2>
                    <div>Notifications délivrées</div>
                    <small class="text-muted">{{ answered }} répondues</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="mb-0">{{ counts['failed'] }}</h2>
                    <div>Échecs d'envoi</div>
                    <small class="text-muted">{{ counts['planned'] }} planifiées</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header">Répartition des réponses</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="badge text-bg-success">Validées</span><strong>{{ counts['validated'] }}</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="badge text-bg-warning">Reportées</span><strong>{{ counts['postponed'] }}</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="badge text-bg-danger">Non effectuées</span><strong>{{ counts['not_done'] }}</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="badge text-bg-info">En attente de réponse</span><strong>{{ counts['sent'] }}</strong>
                    </li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header">Plan du jour — {{ today|date('d/m/Y') }}</div>
                {% if todayPlan is empty %}
                    <div class="card-body text-muted">Aucune notification planifiée aujourd'hui.</div>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for n in todayPlan %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    {{ n.scheduledAt|date('H:i') }} — {{ n.typeLabel }}
                                    {% if n.status.value == 'postponed' and n.postponedUntil %}
                                        <small class="text-muted">(repop {{ n.postponedUntil|date('H:i') }})</small>
                                    {% endif %}
                                </span>
                                <span class="badge text-bg-{{ n.status.color }}">{{ n.status.label }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
